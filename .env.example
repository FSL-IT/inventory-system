# Application
APP_NAME="FSL Inventory"
APP_ENV=development
APP_URL=http://localhost/fsl-inventory

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fsl_inventory
DB_USER=root
DB_PASS=

# Session
SESSION_LIFETIME=3600
SESSION_NAME=fsl_session

# Security
BCRYPT_COST=12

# Backup Storage
BACKUP_PATH=storage/backups/
